{
  "name": "chur",
  "version": "1.2.0",
  "description": "SEER VERDANDI — Chur RBAC proxy / auth gateway",
  "scripts": {
    "predev": "bash ../../scripts/init-arcadedb.sh || true",
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.8.3",
    "fastify-plugin": "^5.0.0",
    "jose": "^6.2.2",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.0",
    "typescript": "~5.9.0",
    "vitest": "^2.1.9"
  }
}
