# ── Chur BFF — environment variables ─────────────────────────────────────────
# Copy to .env and adjust for your environment.

PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=seer
KEYCLOAK_CLIENT_ID=aida-bff
KEYCLOAK_CLIENT_SECRET=aida-bff-secret-dev   # required in production

# ── Keycloak Admin API (for /heimdall/users) ──────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASS=admin

# ── Session ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=dev-cookie-secret               # required in production

# ── ArcadeDB (for /api/query proxy) ───────────────────────────────────────────
ARCADEDB_URL=http://localhost:2480
ARCADEDB_DB=hound
ARCADEDB_USER=root
ARCADEDB_PASS=playwithdata

# ── Backend services ──────────────────────────────────────────────────────────
HEIMDALL_URL=http://localhost:9093
LINEAGE_API_URL=http://localhost:8080
