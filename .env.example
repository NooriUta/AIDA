# ─── AIDA Dev Environment — Variables Reference ─────────────────────────────
# Copy to .env and adjust values for your local setup.
# Variables marked [REQUIRED in prod] MUST be overridden before deployment.
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  PORT MAP (Dev)                                                          │
# │                                                                          │
# │  Service              Dev (Gradle/npm)   Docker stable   Internal       │
# │  ────────────────────  ─────────────────  ──────────────  ────────────── │
# │  verdandi              :5173              :15173          :5173 (nginx)  │
# │  heimdall-frontend     :5174              :15174          :5174 (nginx)  │
# │  Chur (BFF)            :3000              :13000          :3000          │
# │  shuttle               :8080              :18080          :8080          │
# │  dali                  :9090              :19090          :9090          │
# │  heimdall-backend      :9093              :19093          :9093          │
# │  Keycloak              :18180/kc (Docker only)           :8180/kc       │
# │  ArcadeDB FRIGG        :2481 → :2480      :2481           :2480          │
# │  ArcadeDB Ygg          :2480              :2480           :2480          │
# │                                                                          │
# │  DEV STARTUP (IDE: Dev: All Services compound run config)               │
# │    Docker layer:  docker compose -f docker-compose.stable.yml up -d     │
# │                   (Keycloak 26.6.1, FRIGG 26.4.2, Ygg 26.4.2, Chur)    │
# │    IDE:           Run > Dev: All Services                                │
# │                   → shuttle/dali/heimdall-backend (cmd.exe/gradlew.bat) │
# │                   → chur/verdandi/heimdall-frontend (npm run dev)       │
# └──────────────────────────────────────────────────────────────────────────┘

# ─── General ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Chur (BFF / Auth Gateway) ────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:15173,http://localhost:25174,http://localhost:25175
COOKIE_SECRET=dev-cookie-secret                        # [REQUIRED in prod]
COOKIE_SECURE=false                                    # true in prod (HTTPS)
COOKIE_DOMAIN=localhost

# ─── Keycloak OIDC ─────────────────────────────────────────────────────────
# Internal KC URL (container-to-container in Docker, or localhost for dev)
KEYCLOAK_URL=http://localhost:18180/kc                 # Docker Keycloak
KEYCLOAK_PUBLIC_URL=http://localhost:18180/kc          # Browser-facing KC URL
KEYCLOAK_REALM=seer
KEYCLOAK_CLIENT_ID=aida-bff
KEYCLOAK_CLIENT_SECRET=aida-bff-secret-dev             # [REQUIRED in prod]
KEYCLOAK_CLIENT_ID_HEIMDALL=aida-bff-heimdall
KEYCLOAK_CLIENT_SECRET_HEIMDALL=aida-bff-heimdall-secret-dev  # [REQUIRED in prod]

# KC Admin API (used by Chur for realm introspection)
# After recreating KC container, bootstrap password is reset to admin/admin.
# Change it manually in KC admin UI and update this value.
KC_ADMIN_USER=admin
KC_ADMIN_PASS=admin                                    # change after KC container recreate

# ─── ArcadeDB / Ygg (lineage graph) ───────────────────────────────────────
ARCADEDB_URL=http://localhost:2480
ARCADEDB_DB=hound
ARCADEDB_USER=root
ARCADEDB_PASS=playwithdata                             # [REQUIRED in prod]
ARCADEDB_ROOT_PASSWORD=playwithdata                    # Ygg root password

# ─── FRIGG (ArcadeDB — session/tenant/user store) ─────────────────────────
# FRIGG_URL is set per-environment (Docker: http://frigg:2480, dev: http://localhost:2481)
FRIGG_ROOT_PASSWORD=playwithdata                       # FRIGG container root password [REQUIRED in prod]
FRIGG_PASSWORD=playwithdata                            # Chur → FRIGG Basic auth [REQUIRED in prod]
ARCADEDB_ADMIN_PASSWORD=playwithdata                   # Admin operations password

# ─── Backend services ──────────────────────────────────────────────────────
# Pure dev (Gradle quarkusDev):
LINEAGE_API_URL=http://localhost:8080                  # shuttle
HEIMDALL_URL=http://localhost:9093                     # heimdall-backend
DALI_URL=http://localhost:9090                         # dali

# ─── Login redirect ────────────────────────────────────────────────────────
POST_LOGIN_REDIRECT=http://localhost:5175/             # where to go after auth

# ─── Anthropic (AIDA AI features) ─────────────────────────────────────────
# Use a separate demo/dev key — NOT the production key!
# Rotate after demos: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...                           # [REQUIRED for AIDA]
