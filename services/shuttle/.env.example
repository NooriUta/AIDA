# SHUTTLE — Quarkus GraphQL API
# Quarkus reads QUARKUS_* env vars at startup.
# For local dev without Docker: copy to .env and adjust.

# ArcadeDB connection
QUARKUS_REST_CLIENT_ARCADE_URL=http://localhost:2480
ARCADE_DB=hound
ARCADE_USER=root
ARCADE_PASSWORD=playwithdata                 # [REQUIRED in prod]

# CORS — allowed origins for GraphQL endpoint
QUARKUS_HTTP_CORS_ORIGINS=http://localhost:13000,http://localhost:15173

# HEIMDALL event sink (optional — enables atom-extracted metrics)
HEIMDALL_URL=http://localhost:9093
