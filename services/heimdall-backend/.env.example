# HEIMDALL backend — Quarkus admin observability API
# Quarkus reads QUARKUS_* env vars at startup.
# For local dev without Docker: copy to .env and adjust.

# HTTP port
QUARKUS_HTTP_PORT=9093

# FRIGG — ArcadeDB snapshot DB
QUARKUS_REST_CLIENT_FRIGG_API_URL=http://localhost:2481
FRIGG_DB=heimdall
FRIGG_USER=root
FRIGG_PASSWORD=playwithdata                  # [REQUIRED in prod]

# Docker socket — required for container health introspection
DOCKER_HOST=unix:///var/run/docker.sock

# docker-compose project name (used for container introspection)
COMPOSE_PROJECT_NAME=aida-root
