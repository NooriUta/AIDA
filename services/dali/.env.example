# DALI — Quarkus PL/SQL async parser
# Quarkus reads QUARKUS_* env vars at startup.
# For local dev without Docker: copy to .env and adjust.

# HTTP port
QUARKUS_HTTP_PORT=9090

# FRIGG — ArcadeDB snapshot DB (HEIMDALL state)
FRIGG_URL=http://localhost:2481
FRIGG_DB=dali
FRIGG_USER=root
FRIGG_PASSWORD=playwithdata                  # [REQUIRED in prod]

# YGG / HoundArcade — main lineage DB
YGG_URL=http://localhost:2480

# HEIMDALL event sink
HEIMDALL_URL=http://localhost:9093

# docker-compose project name (used for container introspection)
COMPOSE_PROJECT_NAME=aida-root
