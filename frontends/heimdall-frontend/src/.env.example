# ── Heimdall frontend — environment variables ─────────────────────────────────
# Copy to .env and adjust for your environment.

# Auth proxy (Chur BFF)
VITE_AUTH_URL=http://localhost:3000/auth

# Heimdall backend REST API
VITE_HEIMDALL_API=http://localhost:9093

# Heimdall backend WebSocket (live events)
VITE_HEIMDALL_WS=ws://localhost:9093/ws/events
