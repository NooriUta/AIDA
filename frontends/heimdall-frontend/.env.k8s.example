# ── Heimdall Frontend — Kubernetes values ────────────────────────────────────
# Set at build time (Vite bakes these into the bundle) or use runtime injection.
# For k8s: bake into the image during CI, or use a runtime config endpoint.

VITE_HEIMDALL_API=https://heimdall.yourdomain.com/heimdall/api
VITE_HEIMDALL_WS=wss://heimdall.yourdomain.com/heimdall/ws/events
