# ── Heimdall Frontend — environment variables ─────────────────────────────────
# Copy to .env.local and adjust for your environment.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

VITE_HEIMDALL_API=http://localhost:9093
VITE_HEIMDALL_WS=ws://localhost:9093/ws/events

# ── Vite proxy overrides — copy to .env.local for docker mode ─────────────
# CHUR_PROXY_TARGET=http://127.0.0.1:13000
# DALI_PROXY_TARGET=http://127.0.0.1:19090
# HEIMDALL_PROXY_TARGET=http://127.0.0.1:19093
# JOBRUNR_PROXY_TARGET=http://127.0.0.1:29091
