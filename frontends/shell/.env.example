# Shell — Module Federation host (Vite)
# Copy to .env and adjust for your environment.

# Remote entry points for federated micro-frontends
# Pure dev (local Vite servers):
VITE_VERDANDI_URL=http://localhost:5173/remoteEntry.js
VITE_HEIMDALL_URL=http://localhost:5174/remoteEntry.js

# Docker dev (compose ports):
# VITE_VERDANDI_URL=http://localhost:15173/remoteEntry.js
# VITE_HEIMDALL_URL=http://localhost:25174/remoteEntry.js
