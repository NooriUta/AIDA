            "secret": "aida-bff-secret-dev",
            "directAccessGrantsEnabled": true,
            "standardFlowEnabled": true,
            "implicitFlowEnabled": false,
            "serviceAccountsEnabled": false,
            "publicClient": false,
            "attributes": {
                "pkce.code.challenge.method": "S256",
                "post.logout.redirect.uris": "+"
            },
            "redirectUris": [
                "http://localhost:3000/*",
                "http://localhost:13000/*",
                "http://localhost:5173/*",
                "http://localhost:5174/*",
                "http://localhost:5175/*",
                "https://seidrstudio.pro/*",
                "https://www.seidrstudio.pro/*",
                "https://seer.seidrstudio.pro/*",
                "https://heimdall.seidrstudio.pro/*"
            ],
            "webOrigins": [
                "http://localhost:3000",
                "https://seidrstudio.pro",
                "https://www.seidrstudio.pro",
                "https://seer.seidrstudio.pro",
                "https://heimdall.seidrstudio.pro"
            ],
            "protocol": "openid-connect",
            "defaultClientScopes": [
                "openid",
                "profile",
                "email",
                "roles",
                "organization"
            ],
            "optionalClientScopes": [
                "seer:read",
                "seer:write",
                "aida:harvest",
                "aida:audit",
                "aida:tenant:admin",
                "aida:tenant:owner",
                "aida:admin",
                "aida:admin:destructive",
                "aida:superadmin"
            ],
            "protocolMappers": [
                {
                    "name": "sub-mapper",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-sub-mapper",
                    "consentRequired": false,
                    "config": {
                        "access.token.claim": "true",
                        "id.token.claim": "true",
                        "userinfo.token.claim": "true"
                    }
                },
                {
                    "name": "username-mapper",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-attribute-mapper",
                    "consentRequired": false,
                    "config": {
                        "userinfo.token.claim": "true",
                        "user.attribute": "username",
                        "id.token.claim": "true",
                        "access.token.claim": "true",
                        "claim.name": "preferred_username",
                        "jsonType.label": "String"
                    }
                },
                {
                    "name": "seer-role-mapper",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-realm-role-mapper",
                    "consentRequired": false,
                    "config": {
                        "multivalued": "true",
                        "userinfo.token.claim": "true",
                        "id.token.claim": "true",
                        "access.token.claim": "true",
                        "claim.name": "seer_roles",
                        "jsonType.label": "String"
                    }
                }
            ]
        },
