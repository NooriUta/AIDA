{
  "realm": "seer",
  "enabled": true,
  "organizationsEnabled": false,
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": true,
  "sslRequired": "none",
  "accessTokenLifespan": 14400,
  "ssoSessionIdleTimeout": 36000,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "viewer",
        "description": "Read-only access to lineage data"
      },
      {
        "name": "editor",
        "description": "Read + limited write access, MIMIR with quota"
      },
      {
        "name": "operator",
        "description": "Run harvest, monitor Dali, event stream"
      },
      {
        "name": "auditor",
        "description": "Audit log and tool call trace, read-only"
      },
      {
        "name": "local-admin",
        "description": "Manage tenant users and quotas"
      },
      {
        "name": "tenant-owner",
        "description": "Tenant settings, billing, assign local-admin"
      },
      {
        "name": "admin",
        "description": "Full HEIMDALL, Sources, restart services, DEMODEBUG"
      },
      {
        "name": "super-admin",
        "description": "Platform, cross-tenant, Keycloak realm management"
      }
    ]
  },
  "defaultRoles": [
    "viewer"
  ],
  "clients": [
    {
      "clientId": "aida-bff",
      "name": "AIDA BFF (Chur)",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "aida-bff-secret-dev",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "https://seidrstudio.pro/*",
        "https://www.seidrstudio.pro/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://seidrstudio.pro",
        "https://www.seidrstudio.pro"
      ],
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "seer:read",
        "seer:write",
        "aida:harvest",
        "aida:audit",
        "aida:tenant:admin",
        "aida:tenant:owner",
        "aida:admin",
        "aida:superadmin"
      ],
      "protocolMappers": [
        {
          "name": "sub-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "username-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "seer-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "seer_roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "aida:admin",
      "description": "HEIMDALL admin access — metrics, snapshots, control panel",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "aida:admin:destructive",
      "description": "HEIMDALL destructive ops — reset, cancel sessions",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "seer:read",
      "description": "Read lineage data, LOOM, KNOT, ANVIL",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "seer:write",
      "description": "Save views, annotations, MIMIR full access",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "aida:harvest",
      "description": "Run parse sessions, view Dali, event stream",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "aida:audit",
      "description": "Audit log view and export",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "aida:tenant:admin",
      "description": "Manage tenant users and quotas",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "aida:tenant:owner",
      "description": "Tenant settings, billing, assign local-admin",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "aida:superadmin",
      "description": "Platform settings, cross-tenant, Keycloak realm",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
