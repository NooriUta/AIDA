{
  "realm": "seer",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": true,
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 28800,
  "roles": {
    "realm": [
      { "name": "viewer", "description": "Read-only access to lineage data" },
      { "name": "editor", "description": "Read + limited write access" },
      { "name": "admin",  "description": "Full access including write operations" }
    ]
  },
  "defaultRoles": ["viewer"],
  "clients": [
    {
      "clientId": "aida-bff",
      "name": "AIDA BFF (Chur)",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "aida-bff-secret-dev",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": false,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "seer-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "seer_roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "aida:admin",
      "description": "HEIMDALL admin access — metrics, snapshots, control panel",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "aida:admin:destructive",
      "description": "HEIMDALL destructive ops — reset, cancel sessions",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    }
  ],
  "users": [
    {
      "username": "admin",
      "firstName": "Admin",
      "lastName": "Seer",
      "email": "admin@seer.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "editor",
      "firstName": "Editor",
      "lastName": "Seer",
      "email": "editor@seer.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "editor",
          "temporary": false
        }
      ],
      "realmRoles": ["editor"]
    },
    {
      "username": "viewer",
      "firstName": "Viewer",
      "lastName": "Seer",
      "email": "viewer@seer.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
