{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "verdandi",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontends/verdandi"
    },
    {
      "name": "chur",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "bff/chur"
    },
    {
      "name": "shuttle",
      "runtimeExecutable": "gradlew.bat",
      "runtimeArgs": [":services:shuttle:quarkusDev"],
      "port": 8080,
      "autoPort": false,
      "cwd": "."
    },
    {
      "name": "heimdall-backend",
      "runtimeExecutable": "gradlew.bat",
      "runtimeArgs": [":services:heimdall-backend:quarkusDev"],
      "port": 9093,
      "autoPort": false,
      "cwd": "."
    },
    {
      "name": "heimdall-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--force"],
      "port": 5174,
      "cwd": "frontends/heimdall-frontend"
    },
    {
      "name": "shell",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5175,
      "cwd": "frontends/shell"
    },
    {
      "name": "dali",
      "runtimeExecutable": "gradlew.bat",
      "runtimeArgs": [":services:dali:quarkusDev"],
      "port": 9090,
      "autoPort": false,
      "cwd": "."
    },
    {
      "name": "docs-specs",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "5199", "--directory", "C:/AIDA/docs/current/specs"],
      "port": 5199,
      "cwd": "."
    },
    {
      "name": "heimdall-frontend-docker",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const h=require('http');const r=h.request({host:'localhost',port:25174,path:req.url,method:req.method,headers:req.headers},pr=>{res.writeHead(pr.statusCode,pr.headers);pr.pipe(res);});req.pipe(r);r.on('error',e=>{res.writeHead(502);res.end(e.message);});}).listen(5180,()=>console.log('proxy 5180 → docker 25174'))"],
      "port": 5180,
      "cwd": "."
    }
  ]
}
