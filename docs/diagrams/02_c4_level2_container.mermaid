---
title: AIDA C4 Level 2 Container Diagram
---
graph TB
    classDef working fill:#1e3a1e,stroke:#4ade80,stroke-width:2px,color:#fff
    classDef new fill:#3a2e1e,stroke:#fbbf24,stroke-width:2px,color:#fff
    classDef planned fill:#2e2e3a,stroke:#94a3b8,stroke-width:1px,color:#fff,stroke-dasharray: 5 5
    classDef infra fill:#2e1e3a,stroke:#a78bfa,stroke-width:2px,color:#fff
    classDef external fill:#1e2e3a,stroke:#60a5fa,stroke-width:1px,color:#fff
    classDef gradle fill:#1a1a2e,stroke:#f472b6,stroke-width:3px,color:#fff,stroke-dasharray: 3 3

    BROWSER["Browsers<br/>Users · Admins"]
    EXTDB[("Source DBs")]
    CLAUDE["Claude API"]
    OLLAMA["Ollama"]

    subgraph FRONT["FRONTENDS"]
        VERDANDI["VERDANDI · React 19<br/>LOOM · KNOT<br/>+ ANVIL UI · MIMIR Chat"]
        HEIMDALL_FE["HEIMDALL frontend<br/>React admin panel"]
        URD_FE["URD frontend<br/>planned"]
        SKULD_FE["SKULD frontend<br/>planned"]
    end

    CHUR["Chur · Node.js Fastify<br/>BFF · Auth · GraphQL proxy"]

    subgraph GRADLE["AIDA Gradle Multi-Module Project · JVM"]
        SHUTTLE["SHUTTLE<br/>Quarkus · SmallRye GraphQL"]
        DALI["Dali Core<br/>Quarkus + JobRunr"]
        HOUND["Hound · Java library<br/>ANTLR4 · 16 dialects<br/>import by Dali"]
        MIMIR["MIMIR backend<br/>LLM orchestrator"]
        ANVIL_BE["ANVIL backend<br/>Graph algorithms"]
        HEIMDALL_BE["HEIMDALL backend<br/>Event collector · control"]
    end

    subgraph DATA["DATA LAYER"]
        YGG[("YGG · HoundArcade<br/>ArcadeDB latest<br/>Lineage data")]
        FRIGG[("FRIGG<br/>ArcadeDB latest<br/>Views · prefs · JobRunr")]
    end

    KC["Keycloak 26.2"]

    BROWSER --> VERDANDI
    BROWSER --> HEIMDALL_FE
    BROWSER -.-> URD_FE
    BROWSER -.-> SKULD_FE
    VERDANDI --> CHUR
    HEIMDALL_FE --> CHUR
    CHUR --> SHUTTLE
    CHUR --> HEIMDALL_BE
    CHUR --> KC
    SHUTTLE --> YGG
    SHUTTLE --> DALI
    SHUTTLE --> MIMIR
    SHUTTLE -.-> ANVIL_BE
    DALI ==>|in-JVM| HOUND
    DALI --> FRIGG
    DALI --> EXTDB
    HOUND ==> YGG
    MIMIR --> CLAUDE
    MIMIR --> OLLAMA
    MIMIR --> ANVIL_BE
    MIMIR --> SHUTTLE
    ANVIL_BE --> YGG
    HOUND -.->|events| HEIMDALL_BE
    DALI -.->|events| HEIMDALL_BE
    MIMIR -.->|events| HEIMDALL_BE
    ANVIL_BE -.->|events| HEIMDALL_BE
    SHUTTLE -.->|events| HEIMDALL_BE
    HEIMDALL_BE -.->|control| DALI

    class VERDANDI,CHUR,SHUTTLE,HOUND,YGG working
    class HEIMDALL_FE,HEIMDALL_BE,DALI,MIMIR,ANVIL_BE,FRIGG new
    class URD_FE,SKULD_FE planned
    class KC infra
    class BROWSER,EXTDB,CLAUDE,OLLAMA external
    class GRADLE gradle
