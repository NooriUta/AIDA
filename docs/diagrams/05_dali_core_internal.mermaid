---
title: Dali Core internal architecture
---
graph TB
    classDef entrypoint fill:#1e3a1e,stroke:#4ade80,stroke-width:3px,color:#fff
    classDef jobrunr fill:#3a2e1e,stroke:#fbbf24,stroke-width:2px,color:#fff
    classDef worker fill:#2e1e3a,stroke:#a78bfa,stroke-width:2px,color:#fff
    classDef external fill:#1e2e3a,stroke:#60a5fa,stroke-width:2px,color:#fff
    classDef storage fill:#3a1e1e,stroke:#f87171,stroke-width:2px,color:#fff

    SHUTTLE["SHUTTLE<br/>mutation startParseSession"]
    CRON["JobRunr Cron Scheduler<br/>nightly-harvest"]
    HEIMDALL_CTRL["HEIMDALL backend<br/>control commands"]

    subgraph DALI["Dali Core Quarkus process"]
        REST["REST endpoints<br/>POST /sessions<br/>POST /control/*"]
        HARVEST_JOB["HarvestJob<br/>600-800 LoC"]
        JOBRUNR_CORE["JobRunr Core<br/>Queue · Scheduler<br/>Retry · Progress"]
        STORAGE_ADAPTER["Custom ArcadeDB<br/>StorageProvider<br/>200-400 LoC"]

        subgraph POOL["Worker Pool · 8 workers"]
            W1["Worker-1"]
            W2["Worker-2"]
            W3["Worker-3"]
            WN["Worker-8"]
        end

        EVENT_EMIT["EventEmitter<br/>HEIMDALL bridge"]
    end

    HOUND["Hound · Java library<br/>in-JVM call"]
    FRIGG[("FRIGG ArcadeDB<br/>JobRunr state")]
    YGG[("YGG HoundArcade")]
    EXTDB[("External DBs JDBC")]
    HEIMDALL_EVT["HEIMDALL backend"]

    SHUTTLE -->|POST /sessions<br/>dali-models| REST
    CRON -->|fire trigger| HARVEST_JOB
    HEIMDALL_CTRL -->|reset cancel| REST
    REST --> HARVEST_JOB
    HARVEST_JOB -->|enqueue N subtasks| JOBRUNR_CORE
    HARVEST_JOB --> EVENT_EMIT
    JOBRUNR_CORE --> STORAGE_ADAPTER
    STORAGE_ADAPTER <-->|atomic transitions| FRIGG
    JOBRUNR_CORE -->|dispatch| W1
    JOBRUNR_CORE -->|dispatch| W2
    JOBRUNR_CORE -->|dispatch| W3
    JOBRUNR_CORE -->|dispatch| WN
    W1 -->|JDBC fetch| EXTDB
    W1 ==>|in-JVM parse| HOUND
    HOUND ==>|REMOTE_BATCH| YGG
    W1 -.->|events| EVENT_EMIT
    W2 -.-> EVENT_EMIT
    W3 -.-> EVENT_EMIT
    WN -.-> EVENT_EMIT
    EVENT_EMIT -->|HTTP POST| HEIMDALL_EVT

    class REST,CRON entrypoint
    class HARVEST_JOB,JOBRUNR_CORE,STORAGE_ADAPTER,EVENT_EMIT jobrunr
    class W1,W2,W3,WN worker
    class SHUTTLE,HEIMDALL_CTRL,HOUND,EXTDB,HEIMDALL_EVT external
    class FRIGG,YGG storage
