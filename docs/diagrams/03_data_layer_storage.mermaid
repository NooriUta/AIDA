---
title: AIDA Data Layer — Storage topology
---
graph TB
    classDef primary fill:#1e3a1e,stroke:#4ade80,stroke-width:3px,color:#fff
    classDef secondary fill:#3a2e1e,stroke:#fbbf24,stroke-width:2px,color:#fff
    classDef external fill:#1e2e3a,stroke:#60a5fa,stroke-width:2px,color:#fff
    classDef writer fill:#2e1e3a,stroke:#a78bfa,stroke-width:2px,color:#fff
    classDef reader fill:#1e3a2e,stroke:#34d399,stroke-width:2px,color:#fff

    subgraph YGG_CONTAINER["HoundArcade Container · ArcadeDB latest · :2480"]
        HOUND_DB[("hound database<br/>Production lineage<br/>15 vertex types<br/>32 edge types<br/>Schema v26")]
        PREVIEW_DB[("preview-session-N<br/>Temporary databases<br/>For UC2a preview<br/>Q31 pending")]
    end

    subgraph FRIGG_CONTAINER["FRIGG Container · ArcadeDB latest · :2481"]
        VIEWS_DB[("frigg-views<br/>Saved LOOM views")]
        PREFS_DB[("frigg-prefs<br/>User preferences")]
        JOBRUNR_DB[("frigg-jobrunr<br/>JobRunr state<br/>Custom StorageProvider")]
    end

    subgraph FS["File System · Mounted Volume"]
        SOURCES["/data/sql-sources<br/>Raw SQL scripts"]
    end

    subgraph EXT["External Source DBs"]
        ORACLE[("Oracle · PL/SQL")]
        POSTGRES[("PostgreSQL")]
        CH[("ClickHouse")]
    end

    HOUND["Hound · Java library"]
    DALI["Dali Core · Quarkus + JobRunr"]
    SHUTTLE["SHUTTLE · Quarkus GraphQL"]
    ANVIL_BE["ANVIL backend"]
    MIMIR["MIMIR backend"]

    HOUND ==>|3 modes EMBEDDED/REMOTE/BATCH| HOUND_DB
    HOUND -.->|UC2a preview| PREVIEW_DB
    DALI -->|JDBC UC1 harvest| ORACLE
    DALI -->|JDBC| POSTGRES
    DALI -->|JDBC| CH
    DALI -->|read files| SOURCES
    DALI ==>|in-JVM call| HOUND
    DALI -->|JobRunr persistence| JOBRUNR_DB
    SHUTTLE -->|Cypher reads| HOUND_DB
    SHUTTLE -->|Views CRUD| VIEWS_DB
    SHUTTLE -->|User prefs| PREFS_DB
    ANVIL_BE -->|Cypher traversal| HOUND_DB
    MIMIR -->|Direct read tools| HOUND_DB

    class HOUND_DB,VIEWS_DB,PREFS_DB,JOBRUNR_DB primary
    class PREVIEW_DB secondary
    class SOURCES,ORACLE,POSTGRES,CH external
    class HOUND,DALI writer
    class SHUTTLE,ANVIL_BE,MIMIR reader
