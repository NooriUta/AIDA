    end

    HEIMDALL_FE["HEIMDALL frontend<br/>Separate React project"]
    URD_FE["URD frontend planned"]
    SKULD_FE["SKULD frontend planned"]
    CHUR["Chur BFF"]

    SHELL --> LOOM_ROUTE
    SHELL --> KNOT_ROUTE
