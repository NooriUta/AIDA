    classDef service fill:#1e2e3a,stroke:#60a5fa,stroke-width:2px,color:#fff

    subgraph VERDANDI_APP["VERDANDI · React 19 SPA · :15173"]
        SHELL["Shell<br/>Router · Layout<br/>Header · StatusBar"]

        subgraph ROUTES["Routes"]
            LOOM_ROUTE["/ LoomCanvas"]
