---
title: AIDA deployment topology docker-compose
---
graph TB
    classDef public fill:#1e3a1e,stroke:#4ade80,stroke-width:3px,color:#fff
    classDef internal fill:#3a2e1e,stroke:#fbbf24,stroke-width:2px,color:#fff
    classDef data fill:#2e1e3a,stroke:#a78bfa,stroke-width:2px,color:#fff
    classDef infra fill:#3a1e1e,stroke:#f87171,stroke-width:2px,color:#fff
    classDef external fill:#1e2e3a,stroke:#60a5fa,stroke-width:2px,color:#fff

    USER["User browser"]
    PROXY["Reverse proxy<br/>Caddy/Nginx TBD"]

    subgraph COMPOSE["docker-compose · aida_net · single host"]
        subgraph PUBLIC_TIER["Public tier"]
            VERDANDI_SVC["VERDANDI :15173"]
            HEIMDALL_FE_SVC["HEIMDALL frontend :14000"]
            CHUR_SVC["Chur :3000 Fastify BFF"]
            KC_SVC["Keycloak :8080 realm seer"]
        end

        subgraph JVM_TIER["JVM tier · Gradle multi-module · internal"]
            SHUTTLE_SVC["shuttle :8090"]
            DALI_SVC["dali :9090<br/>Hound as library"]
            MIMIR_SVC["mimir-backend :9091"]
            ANVIL_SVC["anvil-backend :9092"]
            HEIMDALL_BE_SVC["heimdall-backend :9093"]
        end

        subgraph DATA_TIER["Data tier · internal"]
            YGG_SVC[("houndarcade :2480<br/>ArcadeDB latest")]
            FRIGG_SVC[("frigg :2481<br/>ArcadeDB latest")]
        end

        OLLAMA_SVC["ollama :11434<br/>Qwen model"]
    end

    VOLUMES[("Volumes<br/>houndarcade_data<br/>frigg_data<br/>keycloak_data<br/>ollama_models<br/>demo_snapshots")]
    SQL_FILES[("Bind mount<br/>/data/sql-sources")]

    USER -->|HTTPS| PROXY
    PROXY --> VERDANDI_SVC
    PROXY --> HEIMDALL_FE_SVC
    PROXY --> CHUR_SVC
    PROXY --> KC_SVC
    VERDANDI_SVC --> CHUR_SVC
    HEIMDALL_FE_SVC --> CHUR_SVC
    CHUR_SVC --> SHUTTLE_SVC
    CHUR_SVC --> HEIMDALL_BE_SVC
    CHUR_SVC --> KC_SVC
    SHUTTLE_SVC --> YGG_SVC
    SHUTTLE_SVC --> DALI_SVC
    SHUTTLE_SVC --> MIMIR_SVC
    DALI_SVC --> FRIGG_SVC
    DALI_SVC ==>|Hound in-JVM| YGG_SVC
    MIMIR_SVC --> OLLAMA_SVC
    MIMIR_SVC --> ANVIL_SVC
    MIMIR_SVC --> YGG_SVC
    ANVIL_SVC --> YGG_SVC
    YGG_SVC -.-> VOLUMES
    FRIGG_SVC -.-> VOLUMES
    KC_SVC -.-> VOLUMES
    OLLAMA_SVC -.-> VOLUMES
    DALI_SVC -.-> SQL_FILES

    class VERDANDI_SVC,HEIMDALL_FE_SVC,CHUR_SVC,KC_SVC public
    class SHUTTLE_SVC,DALI_SVC,MIMIR_SVC,ANVIL_SVC,HEIMDALL_BE_SVC internal
    class YGG_SVC,FRIGG_SVC data
    class OLLAMA_SVC,VOLUMES,SQL_FILES infra
    class USER,PROXY external
